{
  "name": "@react-form-engine/renderers-html",
  "version": "0.1.0",
  "description": "Accessible field renderers for @react-form-engine/core built on native HTML elements.",
  "license": "MIT",
  "author": "Rodrigo Martins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xKirtle/react-form-engine.git",
    "directory": "packages/renderers-html"
  },
  "homepage": "https://github.com/xKirtle/react-form-engine#readme",
  "bugs": "https://github.com/xKirtle/react-form-engine/issues",
  "keywords": [
    "react",
    "form",
    "forms",
    "renderers",
    "accessibility"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@react-form-engine/core": ">=0.1.0 <1.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@react-form-engine/core": "workspace:*",
    "@tanstack/react-form": "^1.33.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

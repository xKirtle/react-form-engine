{
  "name": "@react-form-engine/core",
  "version": "0.0.0",
  "description": "Data-driven form engine for React: typed field schemas, composable modules, rules, and headless rendering on top of TanStack Form.",
  "license": "MIT",
  "author": "Rodrigo Martins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xKirtle/react-form-engine.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/xKirtle/react-form-engine#readme",
  "bugs": "https://github.com/xKirtle/react-form-engine/issues",
  "keywords": [
    "react",
    "form",
    "forms",
    "schema",
    "headless",
    "tanstack-form"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@tanstack/react-form": "^1.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@tanstack/react-form": "^1.33.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
